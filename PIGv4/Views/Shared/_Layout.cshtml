@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PIG v4.0</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PIGv4.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow" style="background-color: Navy;">
            <div class="container-fluid">
                <img class="me-2" src="~/pics/pig.ico" alt="Pig Logo" />
                <a id="PIGTitle" class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" style="color: HotPink;">PIG v4</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" style="color: HotPink;">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="Import and Export songs" asp-area="" asp-controller="Impex" asp-action="Index">Impex</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="See/Play Songs" asp-area="" asp-controller="Songs" asp-action="Index">Songs</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="See/Play Artists" asp-area="" asp-controller="Artists" asp-action="Index">Artists</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="See/Play PlayLists" asp-area="" asp-controller="PlayLists" asp-action="Index">Gen Playlists</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="Export songs, folders, and playlists" asp-area="" asp-controller="Export" asp-action="Index">Export</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="Manage song folders for export" asp-area="" asp-controller="Folders" asp-action="Index">Folders</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <!-- Mini player (visible when sidebar closed and song playing) -->
                        <li class="nav-item d-flex align-items-center me-3" id="miniPlayer" style="display:none !important;">
                            <span id="miniTitle" class="text-light small me-2" style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></span>
                            <span class="transport-controls">
                            <button class="btn btn-sm btn-outline-light py-0 px-1 me-1" onclick="pigPlayer.prev()" title="Previous"><i class="bi bi-skip-backward-fill"></i></button>
                            <button class="btn btn-sm btn-outline-light py-0 px-1 me-1" id="miniPlayBtn" onclick="pigPlayer.toggle()" title="Play/Pause"><i class="bi bi-play-fill"></i></button>
                            <button class="btn btn-sm btn-outline-light py-0 px-1 me-1" onclick="pigPlayer.stop()" title="Stop"><i class="bi bi-stop-fill"></i></button>
                            <button class="btn btn-sm btn-outline-light py-0 px-1 me-1" onclick="pigPlayer.next()" title="Next"><i class="bi bi-skip-forward-fill"></i></button>
                            <button class="btn btn-sm btn-outline-light py-0 px-1 me-1" id="miniShuffleBtn" onclick="pigPlayer.toggleShuffle()" title="Shuffle"><i class="bi bi-shuffle"></i></button>
                            <button class="btn btn-sm btn-outline-light py-0 px-1" id="miniRepeatBtn" onclick="pigPlayer.toggleRepeat()" title="Repeat"><i class="bi bi-arrow-repeat"></i></button>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" href="#" title="Music Player" id="playerToggleBtn" onclick="togglePlayerSidebar()">
                                <i class="bi bi-music-note-beamed" style="font-size: 1.2rem;"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link navpig-link" title="Settings" asp-area="" asp-controller="Settings" asp-action="Index">
                                <i class="bi bi-gear-fill" style="font-size: 1.2rem;"></i>
                            </a>
                        </li>
                        <!-- Backup indicator -->
                        <li class="nav-item d-flex align-items-center" id="backupIndicator" style="display:none !important;">
                            <span class="spinner-border spinner-border-sm text-warning me-1"></span>
                            <small class="text-warning">Backup...</small>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 - PIGv4 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></span>
            <span class="small">v@(Configuration["App:Version"])</span>
        </div>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/songdetail.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

<!-- Player Sidebar -->
<div id="playerSidebar" class="player-sidebar">
    <div class="p-2">
        <!-- Now Playing + Transport (gold border) -->
        <div class="transport-controls-wrap mb-2">
            <div class="text-center mb-1">
                <button class="btn btn-outline-light btn-sm me-1" onclick="pigPlayer.prev()" title="Previous"><i class="bi bi-skip-backward-fill"></i></button>
                <button class="btn btn-outline-light btn-sm me-1" id="sidebarPlayBtn" onclick="pigPlayer.toggle()" title="Play/Pause"><i class="bi bi-play-fill"></i></button>
                <button class="btn btn-outline-light btn-sm me-1" onclick="pigPlayer.stop()" title="Stop"><i class="bi bi-stop-fill"></i></button>
                <button class="btn btn-outline-light btn-sm me-1" onclick="pigPlayer.next()" title="Next"><i class="bi bi-skip-forward-fill"></i></button>
                <button class="btn btn-outline-light btn-sm me-1" id="sidebarShuffleBtn" onclick="pigPlayer.toggleShuffle()" title="Shuffle"><i class="bi bi-shuffle"></i></button>
                <button class="btn btn-outline-light btn-sm" id="sidebarRepeatBtn" onclick="pigPlayer.toggleRepeat()" title="Repeat"><i class="bi bi-arrow-repeat"></i></button>
            </div>
            <!-- Seek bar -->
            <div class="mb-0 px-1">
                <input type="range" id="seekBar" class="form-range form-range-sm" min="0" max="100" value="0" step="0.1"
                       oninput="pigPlayer.seek(this.value)" />
            </div>
            <div class="d-flex justify-content-between text-muted px-1" style="font-size:0.7rem;">
                <span id="timeElapsed">0:00</span>
                <span id="timeDuration">0:00</span>
            </div>
            <!-- Now playing info -->
            <div class="mt-1 px-1" style="font-size:0.75rem;">
                <div class="d-flex justify-content-between align-items-start">
                    <div style="overflow:hidden; flex:1;">
                        <div><span style="color:cyan;">Title:</span> <span id="sidebarNowPlaying" style="color:HotPink;"></span></div>
                        <div><span style="color:cyan;">Artist:</span> <span id="sidebarArtist" style="color:HotPink;"></span></div>
                        <div><span style="color:cyan;">Album:</span> <span id="sidebarAlbum" style="color:HotPink;"></span></div>
                        <div><span style="color:cyan;">Genre:</span> <span id="sidebarGenre" style="color:HotPink;"></span></div>
                        <div><span style="color:cyan;">Year:</span> <span id="sidebarYear" style="color:HotPink;"></span> <span class="ms-2" style="color:cyan;">Track:</span> <span id="sidebarTrack" style="color:HotPink;"></span></div>
                        <div><span style="color:cyan;">Gen Playlists:</span> <span id="sidebarPlaylists" style="color:HotPink;"></span></div>
                    </div>
                    <div class="ms-2 text-center">
                        <img id="sidebarAlbumArt" src="" alt="" style="display:none; max-width:60px; max-height:60px; border-radius:4px;" />
                        <div class="mt-1">
                            <button class="btn btn-sm btn-outline-light py-0 px-1" id="sidebarEditBtn" onclick="pigPlayer.editCurrentSong()" title="Edit song tags &amp; playlists" style="display:none;">
                                <i class="bi bi-pencil"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Music Selection (collapsible) -->
        <div class="mb-1">
            <a class="d-flex justify-content-between align-items-center text-decoration-none text-warning small" data-bs-toggle="collapse" href="#musicSelection">
                <span><i class="bi bi-sliders me-1"></i>Music Selection</span>
                <i class="bi bi-chevron-down"></i>
            </a>
            <div class="collapse" id="musicSelection">
                <div class="mt-2">
                    <!-- Gen Playlists -->
                    <div class="mb-1">
                        <a class="d-flex justify-content-between align-items-center text-decoration-none text-light small" data-bs-toggle="collapse" href="#genPlaylistList">
                            <span><i class="bi bi-collection-play me-1"></i>Gen Playlists</span>
                            <span id="genPlaylistBadge" class="badge bg-secondary">0</span>
                        </a>
                        <div class="collapse" id="genPlaylistList">
                            <input type="text" class="form-control form-control-sm bg-dark text-light border-secondary mt-1 mb-1 filter-list-search"
                                   placeholder="&#x1F50D; Filter playlists..." data-target="filterGenPlaylists" oninput="pigPlayer.filterCheckList(this)" />
                            <div class="filter-check-list mt-1" id="filterGenPlaylists"></div>
                        </div>
                    </div>
                    <!-- Folders -->
                    <div class="mb-1">
                        <a class="d-flex justify-content-between align-items-center text-decoration-none text-light small" data-bs-toggle="collapse" href="#folderList">
                            <span><i class="bi bi-folder me-1"></i>Folders</span>
                            <span id="folderBadge" class="badge bg-secondary">0</span>
                        </a>
                        <div class="collapse" id="folderList">
                            <input type="text" class="form-control form-control-sm bg-dark text-light border-secondary mt-1 mb-1 filter-list-search"
                                   placeholder="&#x1F50D; Filter folders..." data-target="filterFolders" oninput="pigPlayer.filterCheckList(this)" />
                            <div class="filter-check-list mt-1" id="filterFolders"></div>
                        </div>
                    </div>
                    <!-- Genres -->
                    <div class="mb-1">
                        <a class="d-flex justify-content-between align-items-center text-decoration-none text-light small" data-bs-toggle="collapse" href="#genreList">
                            <span><i class="bi bi-music-note me-1"></i>Genres</span>
                            <span id="genreBadge" class="badge bg-secondary">0</span>
                        </a>
                        <div class="collapse" id="genreList">
                            <input type="text" class="form-control form-control-sm bg-dark text-light border-secondary mt-1 mb-1 filter-list-search"
                                   placeholder="&#x1F50D; Filter genres..." data-target="filterGenres" oninput="pigPlayer.filterCheckList(this)" />
                            <div class="filter-check-list mt-1" id="filterGenres"></div>
                        </div>
                    </div>
                    <!-- Artists -->
                    <div class="mb-1">
                        <a class="d-flex justify-content-between align-items-center text-decoration-none text-light small" data-bs-toggle="collapse" href="#artistList">
                            <span><i class="bi bi-person me-1"></i>Artists</span>
                            <span id="artistBadge" class="badge bg-secondary">0</span>
                        </a>
                        <div class="collapse" id="artistList">
                            <input type="text" class="form-control form-control-sm bg-dark text-light border-secondary mt-1 mb-1 filter-list-search"
                                   placeholder="&#x1F50D; Filter artists..." data-target="filterArtists" oninput="pigPlayer.filterCheckList(this)" />
                            <div class="filter-check-list mt-1" id="filterArtists"></div>
                        </div>
                    </div>
                </div>
                <hr class="border-secondary my-2" />
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <small class="text-muted"><span id="browseCount">0</span> songs</small>
                </div>
                <!-- Song list -->
                <div id="songList" class="song-list"></div>
            </div>
        </div>
    </div>
</div>

<!-- Song Edit Modal (from player) -->
<div class="modal fade" id="playerSongEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header" style="background-color: Maroon;">
                <h6 class="modal-title" style="color: HotPink;">Edit Song</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="playerSongEditBody"></div>
        </div>
    </div>
</div>

<!-- Hidden audio element -->
<audio id="audioElement" preload="auto"></audio>

<!-- Artist Songs Picker Modal -->
<div class="modal fade" id="artistSongsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header" style="background-color: Maroon;">
                <h6 class="modal-title" id="artistSongsTitle" style="color: HotPink;"></h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <button class="btn btn-outline-info btn-sm me-1" onclick="pigPlayer.artistSongsSelectAll(true)">Select All</button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="pigPlayer.artistSongsSelectAll(false)">Select None</button>
                </div>
                <div id="artistSongsList"></div>
            </div>
            <div class="modal-footer">
                <small class="text-muted me-auto"><span id="artistSongsCount">0</span> selected</small>
                <button type="button" class="btn btn-outline-light btn-sm" data-bs-dismiss="modal" onclick="pigPlayer.applyArtistSongs()">Apply</button>
            </div>
        </div>
    </div>
</div>

    <script src="~/js/player.js" asp-append-version="true"></script>
</body>
</html>
